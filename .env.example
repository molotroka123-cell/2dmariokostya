# === Database ===
# Для локальной разработки заведите бесплатный Postgres на Neon/Supabase
# или поднимите локальный через Docker:
#   docker run -p 5432:5432 -e POSTGRES_PASSWORD=pg postgres:16
# Примеры:
#   Local Docker:  postgresql://postgres:pg@localhost:5432/vreahvibes
#   Neon:          postgresql://user:pass@ep-xxx.aws.neon.tech/vreahvibes?sslmode=require
DATABASE_URL="postgresql://postgres:pg@localhost:5432/vreahvibes"

# === NextAuth ===
# Сгенерируйте: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# === Первый администратор (для prisma/seed.ts) ===
ADMIN_EMAIL="admin@vreahvibes.local"
ADMIN_PASSWORD="change-me"
